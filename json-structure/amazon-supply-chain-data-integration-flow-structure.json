{
  "type": "object",
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-supply-chain/refs/heads/main/json-structure/amazon-supply-chain-data-integration-flow-structure.json",
  "name": "DataIntegrationFlow",
  "description": "A data integration flow definition",
  "properties": {
    "instanceId": {
      "type": "string",
      "description": "The instance identifier",
      "example": "inst-abc12345"
    },
    "name": {
      "type": "string",
      "description": "The flow name",
      "example": "MyIntegrationFlow"
    },
    "sources": {
      "type": "array",
      "description": "Data sources for the flow",
      "items": {
        "type": "object"
      }
    },
    "transformation": {
      "type": "object",
      "description": "Data transformation configuration"
    },
    "target": {
      "type": "object",
      "description": "Data target configuration"
    },
    "createdTime": {
      "type": "datetime",
      "description": "Creation timestamp"
    },
    "lastModifiedTime": {
      "type": "datetime",
      "description": "Last modification timestamp"
    }
  }
}